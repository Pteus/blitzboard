<div id="<%= dom_id player %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= player.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Level:</strong>
    <%= player.level %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Sh:</strong>
    <%= player.sh %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Pa:</strong>
    <%= player.pa %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Bl:</strong>
    <%= player.bl %>
  </div>
  <div>
    <strong class="block font-medium mb-1">En:</strong>
    <%= player.en %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Sp:</strong>
    <%= player.sp %>
  </div>
  <div>
    <strong class="block font-medium mb-1">At:</strong>
    <%= player.at %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Team:</strong>
    <%= player.team_id %>
  </div>
</div>
