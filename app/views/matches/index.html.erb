<h1>Match History</h1>

<table>
  <thead>
  <tr>
    <th>Date</th>
    <th>Home</th>
    <th>Score</th>
    <th>Away</th>
  </tr>
  </thead>
  <tbody>
  <% @matches.each do |match| %>
    <tr>
      <td><%= match.played_at.strftime("%b %-d, %Y") %></td>
      <td><%= match.home_team.name %></td>
      <td><%= match.home_score %> — <%= match.away_score %></td>
      <td><%= match.away_team.name %></td>
    </tr>
  <% end %>
  </tbody>
</table>