<div class="space-y-8">
  <h1>League Standings</h1>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
      <tr class="text-xs uppercase tracking-widest primary">
        <th class="pb-3 text-left">#</th>
        <th class="pb-3 text-left">Team</th>
        <th class="pb-3 text-center">P</th>
        <th class="pb-3 text-center">W</th>
        <th class="pb-3 text-center">D</th>
        <th class="pb-3 text-center">L</th>
        <th class="pb-3 text-center">GF</th>
        <th class="pb-3 text-center">GA</th>
        <th class="pb-3 text-center">PTs</th>
      </tr>
      </thead>
      <tbody>
      <% @standings.each_with_index do |row, i| %>
        <tr class="table-row <%= 'font-semibold accent' if i == 0 %>">
          <td class="py-3"><%= i + 1 %></td>
          <td class="py-3 hover:underline"> <%= link_to row[:team].name, team_path(row[:team]) %></td>
          <td class="py-3 text-center"><%= row[:played] %></td>
          <td class="py-3 text-center"><%= row[:wins] %></td>
          <td class="py-3 text-center"><%= row[:draws] %></td>
          <td class="py-3 text-center"><%= row[:losses] %></td>
          <td class="py-3 text-center"><%= row[:goals_for] %></td>
          <td class="py-3 text-center"><%= row[:goals_against] %></td>
          <td class="py-3 text-center font-bold"><%= row[:points] %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl primary">Recent Results</h2>

  <div class="grid gap-3">
    <% @matches.each do |match| %>
      <div class="card p-4 flex items-center justify-between">
        <span class="font-semibold"><%= link_to match.home_team.name, match.home_team %></span>
        <span class="badge-primary text-lg"><%= match.home_score %> — <%= match.away_score %></span>
        <span class="font-semibold"><%= link_to match.away_team.name, match.away_team %></span>
      </div>
    <% end %>
  </div>
</div>